{
  "name": "@closet/core",
  "version": "0.1.0",
  "description": "Personal wardrobe management — transport-agnostic core",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "telegram": "tsx src/transport/telegram/index.ts",
    "web:dev": "concurrently \"tsx watch src/transport/web/server.ts\" \"vite --config src/transport/web/app/vite.config.ts\"",
    "web:build": "cd src/transport/web/app && npm run build",
    "web": "NODE_ENV=production tsx src/transport/web/server.ts"
  },
  "dependencies": {
    "@google/genai": "latest",
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/files": "^1.2.0",
    "better-sqlite3": "latest",
    "cookie-parser": "latest",
    "cors": "latest",
    "dotenv": "^17.3.1",
    "drizzle-orm": "latest",
    "express": "latest",
    "grammy": "^1.41.1",
    "multer": "latest",
    "nanoid": "latest",
    "sharp": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/cookie-parser": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/multer": "latest",
    "@types/node": "latest",
    "@types/supertest": "latest",
    "concurrently": "latest",
    "drizzle-kit": "latest",
    "supertest": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
