GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id
WEB_AUTH_PASSWORD=choose_a_strong_password
# Public HTTPS URL for Telegram Mini App
# Dev: patched automatically by `npm run dev` (cloudflared quick tunnel)
# Docker option A — named tunnel (permanent): set to your Cloudflare hostname
# Docker option B — quick tunnel: run `docker compose logs cloudflared | grep trycloudflare` after startup
WEB_APP_URL=https://your-tunnel-url-here
# Cloudflare named tunnel token (docker-compose option A only)
# Create at dash.cloudflare.com → Zero Trust → Networks → Tunnels
# CLOUDFLARE_TUNNEL_TOKEN=
# Optional: override default port (default: 3000)
# WEB_PORT=3000
# AI model for vision/text tasks — defaults to gemma-4-flash (same API key, lower cost)
# Change to gemini-2.0-flash or gemini-flash-latest to use Gemini instead
# VISION_MODEL=gemma-4-flash
